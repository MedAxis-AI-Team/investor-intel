ANTHROPIC_API_KEY=change-me
GH_TOKEN=change-me

# Database
# Required for /ingest/* endpoints and investor_source consolidation in /score-investors.
# Use the SESSION POOLER URL (port 5432) — NOT the direct host or transaction pooler (port 6543).
# asyncpg requires session mode; transaction mode does not support prepared statements.
# Get from: Supabase dashboard → Project Settings → Database → Connection string → Session pooler tab
SUPABASE_CONNECTION_STRING=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Optional
ENVIRONMENT=development
REQUEST_TIMEOUT_SECONDS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60

# LLM configuration (optional)
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096

# Confidence + scoring (optional)
CONFIDENCE_HIGH_THRESHOLD=0.8
CONFIDENCE_MEDIUM_THRESHOLD=0.6
EVIDENCE_MISSING_PENALTY=0.25

# 6-axis scoring weights (must sum to 1.0)
SCORE_WEIGHT_THESIS_ALIGNMENT=0.30
SCORE_WEIGHT_STAGE_FIT=0.25
SCORE_WEIGHT_CHECK_SIZE_FIT=0.15
SCORE_WEIGHT_SCIENTIFIC_REGULATORY_FIT=0.15
SCORE_WEIGHT_RECENCY=0.10
SCORE_WEIGHT_GEOGRAPHY=0.05
