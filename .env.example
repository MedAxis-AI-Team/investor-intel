API_KEY=change-me
ANTHROPIC_API_KEY=change-me

# Optional
ENVIRONMENT=development
REQUEST_TIMEOUT_SECONDS=20
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60

# LLM configuration (optional)
LLM_MODEL=claude-3-5-sonnet-latest
LLM_MAX_TOKENS=800

# Confidence + scoring (optional)
CONFIDENCE_HIGH_THRESHOLD=0.8
CONFIDENCE_MEDIUM_THRESHOLD=0.6
EVIDENCE_MISSING_PENALTY=0.25
SCORE_WEIGHT_THESIS_ALIGNMENT=0.4
SCORE_WEIGHT_STAGE_FIT=0.2
SCORE_WEIGHT_CHECK_SIZE_FIT=0.2
SCORE_WEIGHT_STRATEGIC_VALUE=0.2
